rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 퀴즈 - 누구나 읽기, 관리자 전체 쓰기, 일반 업데이트는 필드 제한
    match /quizzes/{quizId} {
      allow read: if true;

      // 관리자: 생성/수정 전부 허용
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (onlyUpdatingFields(['bounty', 'challengers', 'wrongAnswers',
                                           'solvedBy', 'solvedAt', 'activePlayers'])
                        && incomingBounty()
                        && incomingActivePlayers());

      // 삭제 불가
      allow delete: if false;
    }

    // 유저 문서 - 누구나 읽기/쓰기 (Firebase Auth 미연동으로 인한 임시)
    // TODO: Custom Token 연동 후 request.auth.uid == userId 조건 추가
    match /users/{userId} {
      allow read: if true;
      allow create: if validUserCreate();
      allow update: if validUserUpdate();
      allow delete: if false;
    }

    // 상품권
    match /giftCards/{cardId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 환전 신청
    match /exchanges/{exchangeId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['uid', 'amount', 'status', 'requestedAt'])
                    && request.resource.data.status == 'pending'
                    && request.resource.data.amount >= 20000;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 관리자 알림
    match /adminAlerts/{alertId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // --- 헬퍼 함수 ---

    function isAdmin() {
      return request.auth != null && request.auth.uid == '4833965068';
    }

    function onlyUpdatingFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function incomingBounty() {
      return !('bounty' in request.resource.data)
        || request.resource.data.bounty is int
        || request.resource.data.bounty == resource.data.bounty + 1;
    }

    function incomingActivePlayers() {
      return !('activePlayers' in request.resource.data)
        || request.resource.data.activePlayers is int;
    }

    function validUserCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['points', 'attempts', 'joinedAt', 'newbieBonusClaimed'])
        && d.points is int
        && d.points >= 0
        && d.attempts == 0
        && d.newbieBonusClaimed == false;
    }

    function validUserUpdate() {
      let d = request.resource.data;
      return (!('points' in d) || d.points is int)
        && (!('attempts' in d) || d.attempts is int);
    }
  }
}
